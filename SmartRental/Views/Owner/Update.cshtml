```cshtml
@model SmartRental.ViewModel.ApartmentVM
@using SmartRental.Models.Entites

@{
    ViewData["Title"] = "Update Apartment";
}

<h1>Update Apartment</h1>

<hr />

<div class="row">
    <div class="col-md-6">

        <form asp-action="Update" method="post" enctype="multipart/form-data">

            <input asp-for="Id" type="hidden" />

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Rooms"></label>
                <input asp-for="Rooms" class="form-control" />
                <span asp-validation-for="Rooms" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Bathrooms"></label>
                <input asp-for="Bathrooms" class="form-control" />
                <span asp-validation-for="Bathrooms" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="MaxTenants"></label>
                <input asp-for="MaxTenants" class="form-control" />
                <span asp-validation-for="MaxTenants" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Description"></label>
                <input asp-for="Description" class="form-control" />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Price"></label>
                <input asp-for="Price" class="form-control" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Gender"></label>
                <select asp-for="Gender"
                        asp-items="Html.GetEnumSelectList<Gender>()"
                        class="form-control">
                </select>
            </div>

            <div class="form-group">
                <label asp-for="AvailabilityStatus"></label>
                <select asp-for="AvailabilityStatus"
                        asp-items="Html.GetEnumSelectList<Status>()"
                        class="form-control">
                </select>
            </div>

            <div class="form-group">
                <label asp-for="City"></label>
                <input asp-for="City" class="form-control" />
            </div>

            <div class="form-group">
                <label asp-for="StreetName"></label>
                <input asp-for="StreetName" class="form-control" />
            </div>

            <div class="form-group">
                <label asp-for="BuildingNumber"></label>
                <input asp-for="BuildingNumber" class="form-control" />
            </div>

            <div class="form-group">
                <label asp-for="ApartmentNumber"></label>
                <input asp-for="ApartmentNumber" class="form-control" />
            </div>

            <div class="form-group">
                <label asp-for="FloorNumber"></label>
                <input asp-for="FloorNumber" class="form-control" />
            </div>

            <div class="form-group">
                <label asp-for="OwnerId"></label>
                <input asp-for="OwnerId" class="form-control" />
            </div>

            @if (Model.CurrentPhotos != null && Model.CurrentPhotos.Any())
            {
                <hr />
                <h4>Current Images</h4>

                <div style="display:flex;flex-wrap:wrap;gap:10px">

                    @foreach (var photo in Model.CurrentPhotos)
                    {
                        <img src="@photo.Url"
                             width="200"
                             height="150"
                             style="border:1px solid #ccc" />
                    }

                </div>
            }

            <hr />

            <div class="form-group">
                <label asp-for="image">Add New Images</label>
                <input asp-for="image"
                       type="file"
                       class="form-control"
                       multiple />
            </div>

            <br />

            <input type="submit"
                   value="Update Apartment"
                   class="btn btn-warning" />

        </form>

    </div>
</div>

@section Scripts
{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

