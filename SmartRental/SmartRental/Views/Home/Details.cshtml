        </a>
    }
    else if (!User.Identity.IsAuthenticated)
    {
        <a asp-controller="Account"
           asp-action="Login"
           class="btn-rent">
            Login To Rent
        </a>
    }


            </div>

        </div>

    </div>

    <div class="comments-section">

        <h3>Comments</h3>

        <p>No comments yet.</p>

    </div>

</div>