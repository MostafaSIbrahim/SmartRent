@model SmartRental.Models.Entites.Apartment

@{
    ViewData["Title"] = "Apartment Details";
}

<div class="details-page">

    <div class="details-card">

        @if (Model.Photos != null && Model.Photos.Any())
        {
            <div id="carouselExample"
                 class="carousel slide">

                <div class="carousel-inner">

                    @{
                        int i = 0;
                    }

                    @foreach (var photo in Model.Photos)
                    {
                        <div class="carousel-item @(i == 0 ? "active" : "")">

                            <img src="@photo.PhotoUrl"
                                 class="details-image">

                        </div>

                        i++;
                    }

                </div>

                <button class="carousel-control-prev"
                        type="button"
                        data-bs-target="#carouselExample"
                        data-bs-slide="prev">

                    <span class="carousel-control-prev-icon"></span>

                </button>

                <button class="carousel-control-next"
                        type="button"
                        data-bs-target="#carouselExample"
                        data-bs-slide="next">

                    <span class="carousel-control-next-icon"></span>

                </button>

            </div>
        }

        <div class="details-content">

            <h2>
                @Model.City - @Model.StreetName
            </h2>

            <p>
                @Model.Description
            </p>

            <div class="details-grid">

                <div><strong>Rooms:</strong> @Model.Rooms</div>

                <div><strong>Bathrooms:</strong> @Model.Bathrooms</div>

                <div><strong>Max Tenants:</strong> @Model.MaxTenants</div>

                <div><strong>Floor Number:</strong> @Model.FloorNumber</div>

                <div><strong>Apartment Number:</strong> @Model.ApartmentNumber</div>

                <div><strong>Gender:</strong> @Model.Gender</div>

                <div><strong>Status:</strong> @Model.AvailabilityStatus</div>

                <div><strong>Price:</strong> @Model.Price EGP</div>

                <div>
                    <strong>Address:</strong>
                    @Model.City,
                    @Model.StreetName,
                    Building @Model.BuildingNumber
                </div>

            </div>

