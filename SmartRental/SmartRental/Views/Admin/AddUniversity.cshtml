@model SmartRental.DTO.UniversityDTO

@{
    ViewData["Title"] = "Add University";
}

<div class="sr-auth-page">

    <div class="sr-auth-card sr-wide">

        <h2 class="sr-title"> University</h2>

        <form asp-action="AddUniversity"
              asp-controller="Admin"
              method="post"
              class="sr-form">

            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly"
                 class="text-danger">
            </div>

            <input asp-for="Name"
                   class="sr-input"
                   placeholder="Full Name" />

            <span asp-validation-for="Name"
                  class="text-danger"></span>

            <input asp-for="City"
                   class="sr-input"
                   placeholder="City" />

            <span asp-validation-for="City"
                  class="text-danger"></span>

            <input asp-for="Area"
                   class="sr-input"
                   placeholder="Area" />

            <span asp-validation-for="Area"
                  class="text-danger"></span>














            <div>

              

             

              
            </div>

          
            <button type="submit"
                    class="sr-btn-primary">
                Add 
            </button>

        </form>


    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
