<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SmartRental</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SmartRental.styles.css" asp-append-version="true" />
</head>
<body>
    <nav class="sr-navbar">
        <div class="sr-container">

            <a class="sr-brand"
               asp-controller="Home"
               asp-action="Index">
                SmartRental
            </a>

            <div class="sr-links">

                <a class="sr-link"
                   asp-controller="Home"
                   asp-action="Index">
                    Home
                </a>

                @if (User?.Identity != null &&
                                User.Identity.IsAuthenticated &&
                                User.IsInRole("Owner"))
                {
                    <a class="sr-link"
                       asp-controller="Owner"
                       asp-action="Index">
                        Owner Properties
                    </a>

                    <a class="sr-link"
                       asp-controller="Owner"
                       asp-action="OwnerIndex">
                        Apartment Actions
                    </a>
                }

                @if (User?.Identity != null &&
                                User.Identity.IsAuthenticated &&
                                User.IsInRole("Admin"))
                {
                    <a class="sr-link"
                       asp-controller="Admin"
                       asp-action="Index">
                        Admin Dashboard
                    </a>
                    <a class="sr-link"
                       asp-controller="Admin"
                       asp-action="Owners">
                        Delete Owner
                    </a>
                    <a class="sr-link"
                       asp-controller="Admin"
                       asp-action="Register">
                        Register Users
                    </a>
                    <a class="sr-link"
                       asp-controller="Admin"
                       asp-action="AddUniversity">
                        Add University
                    </a>

                }

             
                <a class="sr-link"
                   asp-controller="Home"
                   asp-action="Index"
                   asp-fragment="properties">
                    Properties
                </a>

                <a class="sr-link"
                   asp-controller="Home"
                   asp-action="Privacy">
                    Privacy
                </a>

            </div>

            <div class="sr-links">

                @if (User?.Identity != null &&
                                User.Identity.IsAuthenticated)
                {
                    @* <span class="sr-link">
                        @User.Identity.Name
                    </span> *@
                    <a class="sr-link"
                       asp-controller="Profile"
                       asp-action="Index">

                        @User.Identity.Name

                    </a>

                    <form asp-controller="Account"
                          asp-action="Logout"
                          method="post">

                        <button type="submit"
                                class="sr-btn">
                            Logout
                        </button>

                    </form>
                }
                else
                {
                    <a class="sr-link"
                       asp-controller="Account"
                       asp-action="Login">
                        Login
                    </a>

                    <a class="sr-btn-primary"
                       asp-controller="Account"
                       asp-action="Register">
                        Sign Up
                    </a>
                }

            </div>

        </div>
    </nav>
    
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - SmartRental - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>





