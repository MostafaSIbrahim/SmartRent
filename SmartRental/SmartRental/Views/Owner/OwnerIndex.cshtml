@using SmartRental.Models.Entites
@model IEnumerable<Apartment>

<h2>My Apartments</h2>
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}
<table class="table">
    <thead>
        <tr>
            <th>Appartment Number</th>
            <th>Building Number</th>
            <th>Street Name</th>
            <th>City</th>
            <th>Availability Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var apartment in Model)
        {
            <tr>
                <td>@apartment.ApartmentNumber</td>
                <td>@apartment.BuildingNumber</td>
                <td>@apartment.StreetName</td>
                <td>@apartment.City</td>
                <td>@apartment.AvailabilityStatus</td>
                <td>
                    <a asp-action="Update" asp-route-id="@apartment.Id" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@apartment.Id" class="btn btn-sm btn-danger"
                       onclick="return confirm('Are you sure you want to delete this record?');">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
<a asp-action="AddApartment" class="btn btn-primary">Add New Apartment</a>
