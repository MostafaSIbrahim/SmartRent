@using SmartRental.Models.Entites
@model IEnumerable<Apartment>

@{
    ViewData["Title"] = "My Apartments";
}

<div class="owner-page">

    <div class="owner-header">

        <div>
            <h1>My Apartments</h1>
            <p>Manage all your listed properties</p>
        </div>

        <a asp-action="AddApartment"
           class="owner-add-btn">
            + Add Apartment
        </a>

    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="owner-table-card">

        <table class="owner-table">

            <thead>
                <tr>
                    <th>Image</th>
                    <th>Apartment</th>
                    <th>City</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var apartment in Model)
                {
                    var imageUrl =
                    apartment.Photos != null &&
                    apartment.Photos.Any()
                    ? apartment.Photos.First().PhotoUrl
                    : "/images/no-image.jpg";

                    <tr>

                        <td>
                            <img src="@imageUrl"
                                 class="owner-img" />
                        </td>

                        <td>
                            Apt #@apartment.ApartmentNumber
                            <br />
                            <small>
                                Building @apartment.BuildingNumber
                            </small>
                        </td>

                        <td>
                            @apartment.City
                        </td>

                        <td>
                            <span class="status-badge">
                                @apartment.AvailabilityStatus
                            </span>
                        </td>

                        <td>
                            <a asp-action="Update"
                               asp-route-id="@apartment.Id"
                               class="edit-btn">
                                Edit
                            </a>

                            <a href="#"
                               class="delete-btn"
                               onclick="confirmDelete('@Url.Action("Delete","Owner",new { id = apartment.Id })')">
                                Delete
                            </a>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    function confirmDelete(url) {

        Swal.fire({
            title: 'Delete Apartment?',
            text: "This action cannot be undone.",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            cancelButtonColor: '#6b7280',
            confirmButtonText: 'Yes, Delete',
            cancelButtonText: 'Cancel'
        })
            .then((result) => {

                if (result.isConfirmed) {

                    Swal.fire({
                        title: 'Deleted!',
                        text: 'Apartment deleted successfully.',
                        icon: 'success',
                        timer: 1200,
                        showConfirmButton: false
                    });

                    setTimeout(() => {
                        window.location.href = url;
                    }, 1000);
                }

            });
    }
</script>